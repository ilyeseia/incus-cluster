config:
  core.https_address: "{{ tailscale_ip }}:{{ incus_https_port }}"
cluster:
  server_name: "{{ inventory_hostname }}"
  enabled: true
storage_pools:
  - name: "{{ incus_storage_pool }}"
    driver: "{{ incus_storage_driver }}"
networks:
  - name: "{{ incus_network_name }}"
    type: bridge
    config:
      ipv4.address: auto
      ipv4.nat: "true"
      ipv6.address: none
profiles:
  - name: default
    devices:
      root:
        path: /
        pool: "{{ incus_storage_pool }}"
        type: disk
      eth0:
        name: eth0
        network: "{{ incus_network_name }}"
        type: nic
